# ============================================================
# Kino Bot -- Environment configuration
# Copy this file to .env and fill in real values.
# Never commit the real .env file to git.
# ============================================================

# --- Telegram ---
BOT_TOKEN=
BOT_USERNAME=
OWNER_ID=
ADMINS=

# --- Database ---
# Local/Railway volume SQLite by default. Swap to a Postgres URL later
# (e.g. postgresql+asyncpg://user:pass@host:5432/dbname) without code changes.
DATABASE_URL=sqlite+aiosqlite:////data/database.sqlite3

# --- Cache (optional) ---
REDIS_URL=

# --- Logging ---
LOG_LEVEL=INFO

# --- Webhook / Polling ---
USE_WEBHOOK=false
WEBHOOK_URL=
WEBHOOK_SECRET=
HOST=0.0.0.0
PORT=8080

# --- Force Subscribe ---
# Comma separated @username or -100 chat ids, e.g. @channel1,@channel2
FORCE_SUB_CHANNELS=

# --- Localization ---
DEFAULT_LANGUAGE=uz
TIMEZONE=Asia/Tashkent

# --- Security ---
SECRET_KEY=
RATE_LIMIT=5

# --- Storage ---
BACKUP_PATH=/data/backups
LOGS_PATH=/data/logs

# --- Media Sources ---
# Comma separated chat ids of channels/groups the bot reads media from.
MEDIA_CHANNEL_IDS=
MEDIA_GROUP_IDS=

# --- Limits & Features ---
MAX_UPLOAD_SIZE=2000
PREMIUM_ENABLED=true
